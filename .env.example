# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Firestore Collections
FIRESTORE_AGENTS_COLLECTION=agents
FIRESTORE_SESSIONS_COLLECTION=sessions

# Session Management
# Sessions expire after this many minutes of inactivity
# A new conversation session will be created with Vertex AI after expiry
SESSION_TIMEOUT_MINUTES=30

# Slack Configuration
# Comma-separated list of signing secrets (one per Slack app)
# Get each from: api.slack.com/apps → Your App → Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret-1,your-signing-secret-2

# API Configuration
API_V1_PREFIX=/api/v1

# GCS File Upload (Optional but recommended for image support)
# When configured, file attachments are uploaded to GCS and agents receive gs:// URIs
# Leave GCS_BUCKET_NAME empty to use base64 encoding (limited agent support)
# Recommended naming: {PROJECT_ID}-slack-files
GCS_BUCKET_NAME=your-project-id-slack-files
GCS_FILE_PREFIX=slack-files

# Admin UI (optional — leave blank to disable the /admin pages entirely)
# When all four required values are set, the admin UI is mounted at /admin.
# Create the OAuth 2.0 Web Client in GCP Console → APIs & Services →
# Credentials, and add the callback URL below as an authorized redirect URI.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
# Set this to the full callback URL of your deployment:
#   https://<cloud-run-host>/admin/auth/callback
# Or for local dev:
#   http://localhost:8080/admin/auth/callback
# (Google OAuth accepts http://localhost but not http://127.0.0.1.)
OAUTH_REDIRECT_URI=
# Random secret used to sign the admin session cookie. Generate with
# `openssl rand -hex 32`. Required when OAUTH_* are set.
SESSION_SECRET=
# IAM role the operator must hold on GCP_PROJECT_ID to access the admin UI.
ADMIN_REQUIRED_ROLE=roles/owner
# Cloud Run service name used to scope Cloud Logging queries. Defaults to
# "the-forum" (matches the bundled terraform). Override if you renamed it.
CLOUD_RUN_SERVICE_NAME=the-forum

# Local Development Only (optional)
# Uncomment when using Firestore emulator locally
# FIRESTORE_EMULATOR_HOST=localhost:8681
